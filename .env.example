# Exchange
EXCHANGE=binance
SYMBOLS=BTCUSDT,ETHUSDT

# Modes (default: paper + testnet — safest start)
PAPER_TRADING=true
TESTNET=true

# Binance credentials (testnet keys from https://testnet.binancefuture.com)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bybit credentials (testnet from https://testnet.bybit.com)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# OKX credentials (demo trading from OKX account)
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Risk limits
MAX_LEVERAGE=5
MAX_POSITION_SIZE_USD=5000
MAX_DAILY_LOSS_USD=500
MAX_OPEN_POSITIONS=3
COOLDOWN_MS=60000
KELLY_FRACTION=0.5
MIN_STAKE_USD=10
API_ERROR_KILL_THRESHOLD=5

# Strategy
STRATEGY_LOOKBACK=20
STRATEGY_BREAKOUT_MULT=1.5
STRATEGY_MIN_CONFIDENCE=0.55
